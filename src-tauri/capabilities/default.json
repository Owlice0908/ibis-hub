{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    {
      "identifier": "core:event:default",
      "allow": [{ "event": "pty-output-*" }, { "event": "session-*" }]
    }
  ]
}
